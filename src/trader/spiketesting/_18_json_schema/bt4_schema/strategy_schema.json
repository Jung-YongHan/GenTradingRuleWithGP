{
  "$id": "https://example.com/schemas/strategy_schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "version": "1.0.0",
  "definitions": {
    "vola": {
      "type": "object",
      "properties": {
        "support": {
          "type": "boolean"
        },
        "vol_tgt": {
          "type": "number"
        },
        "ga_vol_tgt": {
          "type": "array",
          "items": {
            "type": "number"
          }
        }
      },
      "required": ["support", "vol_tgt", "ga_vol_tgt"]
    },
    "timeframe": {
      "type": "object",
      "properties": {
        "support": {
          "type": "boolean"
        },
        "timeframes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "timegap": {
          "type": "number"
        },
        "ga_timeframes": {
          "type": "boolean"
        },
        "ga_timegap": {
          "type": "array",
          "items": {
            "type": "number"
          }
        }
      },
      "required": ["support", "timeframes", "timegap", "ga_timeframes", "ga_timegap"]
    },
    "fixed": {
      "type": "object",
      "properties": {
        "support": {
          "type": "boolean"
        },
        "hdge": {
          "type": "boolean"
        },
        "trade_ratio": {
          "type": "number"
        },
        "ga_trade_ratio": {
          "type": "array",
          "items": {
            "type": "number"
          }
        }
      },
      "required": ["support", "hdge", "trade_ratio", "ga_trade_ratio"]
    },
    "weighted": {
      "type": "object",
      "properties": {
        "support": {
          "type": "boolean"
        },
        "top_n": {
          "type": "array",
          "items": {
            "type": "number"
          }
        },
        "ga_top_n": {
          "type": "array",
          "items": {
            "type": "array",
            "items": {
              "type": "number"
            }
          }
        }
      },
      "required": ["support", "top_n", "ga_top_n"]
    },
    "stop_loss": {
      "type": "object",
      "properties": {
        "support": {
          "type": "boolean"
        },
        "ratio": {
          "type": "number"
        },
        "ga_ratio": {
          "type": "array",
          "items": {
            "type": "number"
          }
        }
      },
      "required": ["support", "ratio", "ga_ratio"]
    },
    "trailing_stop": {
      "type": "object",
      "properties": {
        "support": {
          "type": "boolean"
        },
        "ratio": {
          "type": "number"
        },
        "ga_ratio": {
          "type": "array",
          "items": {
            "type": "number"
          }
        }
      },
      "required": ["support", "ratio", "ga_ratio"]
    },
    "take_profit": {
      "type": "object",
      "properties": {
        "support": {
          "type": "boolean"
        },
        "ratio": {
          "type": "number"
        },
        "ga_ratio": {
          "type": "array",
          "items": {
            "type": "number"
          }
        }
      },
      "required": ["support", "ratio", "ga_ratio"]
    }
  }
}