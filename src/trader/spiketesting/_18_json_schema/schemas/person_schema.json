{
  "$id": "https://example.com/schemas/person_schema.json",
  "type": "object",
  "properties": {
    "first_name": {
      "type": "string"
    },
    "last_name": {
      "type": "string"
    },
    "age": {
      "type": "integer",
      "minimum": 0
    },
    "address": {
      "$ref": "address_schema.json"
    }
  },
  "required": ["first_name", "last_name", "age", "address"]
}