{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "version": "1.0.0",
"properties": {
    "stgy_name": {
      "type": "string"
    },
    "module_name": {
      "type": "string"
    },
    "ga_exec": {
      "type": "boolean",
      "mode" : {
        "type": "string",
        "enum": ["BASIC", "ADVANCED"]
      }
    },
    "bt_start": {
      "type": "string",
      "format": "date-time"
    },
    "bt_end": {
      "type": "string",
      "format": "date-time"
    },
    "markets": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1,
      "maxItems": 20
    },
    "ga_markets": {
      "type": "boolean"
    },
    "cdl_type": {
      "type": "integer",
      "enum": [1, 3, 5, 15, 30, 60, 240, 1440]
    },
    "init_balance": {
      "type": "number",
      "minimum": 1000000
    },
    "slippage": {
      "type": "number",
      "minimum": 0.0005,
      "maximum": 0.005
    },
    "bt_times": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^([01]\\d|2[0-3]):59$"
      }
    },
    "vola": {
      "$ref": "http://ssel.asuscomm.com:9080/v1/strategy_schema.json#/definitions/vola"
    },
    "timeframe": {
      "$ref": "http://ssel.asuscomm.com:9080/v1/strategy_schema.json#/definitions/timeframe"
    },
    "fixed": {
      "$ref": "http://ssel.asuscomm.com:9080/v1/strategy_schema.json#/definitions/fixed"
    },
    "weighted": {
      "$ref": "http://ssel.asuscomm.com:9080/v1/strategy_schema.json#/definitions/weighted"
    },
    "stop_loss": {
      "$ref": "http://ssel.asuscomm.com:9080/v1/strategy_schema.json#/definitions/stop_loss"
    },
    "trailing_stop": {
      "$ref": "http://ssel.asuscomm.com:9080/v1/strategy_schema.json#/definitions/trailing_stop"
    },
    "take_profit": {
      "$ref": "http://ssel.asuscomm.com:9080/v1/strategy_schema.json#/definitions/take_profit"
    },
    "vars": {
      "$ref": "http://ssel.asuscomm.com:9080/v1/vars_schema.json#/definitions/vars"
    },
    "buy_systems": {
      "$ref": "http://ssel.asuscomm.com:9080/v1/systems_schema.json#/definitions/systems"
    },
    "buy_system_op": {
      "type": "string"
    },
    "sell_systems": {
      "$ref": "http://ssel.asuscomm.com:9080/v1/systems_schema.json#/definitions/systems"
    },
    "sell_system_op": {
      "type": "string"
    }
  },

  "required": ["stgy_name", "module_name", "bt_start", "bt_end", "markets","cdl_type", "init_balance", "slippage","vola", "timeframe", "fixed", "weighted", "stop_loss", "trailing_stop","take_profit","vars", "buy_systems", "buy_system_op", "sell_systems", "sell_system_op"]
}