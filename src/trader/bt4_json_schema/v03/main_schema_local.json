{
  "$id": "http://ssel.asuscomm.com:9080/v1/main_schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "version": "1.0.0",
  "type": "object",
  "properties": {
    "stgy_name": {
      "type": "string"
    },
    "module_name": {
      "type": "string"
    },
    "ga_exec": {
      "type": "boolean"
    },
    "ga_exec_mode": {
        "type": "string",
        "enum": ["BASIC", "ADVANCED", "BEST_EFFORT"]
    },
    "ga_exec_obj": {
        "type": "string",
        "enum": ["PROFIT", "BALANCED"]
    },
    "pt_exec": {
      "type": "boolean"
    },
    "bt_start": {
      "type": "string",
      "format": "date-time"
    },
    "bt_end": {
      "type": "string",
      "format": "date-time"
    },
    "quote_ex": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1,
      "maxItems": 5
    },
    "trade_ex": {
      "type": "string"
    },
    "markets": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1,
      "maxItems": 20
    },
    "ga_markets": {
      "type": "boolean"
    },
    "cdl_type": {
      "type": "integer",
      "enum": [1, 3, 5, 15, 30, 60, 240, 1440]
    },
    "init_balance": {
      "type": "number",
      "minimum": 1000000
    },
  "slippage": {
      "type": "number",
      "minimum": 0.0005,
      "maximum": 0.02
    },
    "bt_times": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^([01]\\d|2[0-3]):59$"
      }
    },
    "vola": {
      "$ref": "strategy_schema.json#/definitions/vola"
    },
    "timeframe": {
      "$ref": "strategy_schema.json#/definitions/timeframe"
    },
    "fixed": {
      "$ref": "strategy_schema.json#/definitions/fixed"
    },
    "weighted": {
      "$ref": "strategy_schema.json#/definitions/weighted"
    },
    "stop_loss": {
      "$ref": "strategy_schema.json#/definitions/stop_loss"
    },
    "trailing_stop": {
      "$ref": "strategy_schema.json#/definitions/trailing_stop"
    },
    "take_profit": {
      "$ref": "strategy_schema.json#/definitions/take_profit"
    },
    "reserved_vars" :{
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 0
    },
    "vars": {
      "$ref": "vars_schema.json#/definitions/vars"
    },
    "buy_sell_systems_pt_ga" : {
      "$ref": "systems_schema.json#/definitions/buy_sell_systems_pt_ga"
    },
    "buy_systems": {
      "$ref": "systems_schema.json#/definitions/systems"
    },
    "buy_system_op": {
      "type": "string"
    },
    "sell_systems": {
      "$ref": "systems_schema.json#/definitions/systems"
    },
    "sell_system_op": {
      "type": "string"
    }
  },

  "required": ["stgy_name", "module_name", "bt_start", "bt_end", "markets","cdl_type", "init_balance", "slippage","vola", "timeframe", "fixed", "weighted", "stop_loss", "trailing_stop","take_profit","vars", "buy_systems", "buy_system_op"]
}